# ==============================================================
# 🛡️ Smart Document Q&A — Streamlit Secrets Template (v3.0)
# ==============================================================
# COPY this file to: .streamlit/secrets.toml
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# On Streamlit Cloud: Settings → Secrets → paste contents there.
#
# ⚠️  NEVER commit secrets.toml to git — it's in .gitignore.
# ⚠️  Generate strong secrets: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ==============================================================

# ── LLM Provider API Keys (ANY ONE is enough to start) ──
# Get FREE NVIDIA key: https://build.nvidia.com/
NVIDIA_API_KEY    = "nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Get FREE Groq key: https://console.groq.com/
GROQ_API_KEY      = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Get OpenRouter key: https://openrouter.ai/
OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── App Branding ──
OWNER_NAME        = "Harsh Bokde"
APP_TAGLINE       = "AI-Powered Document Intelligence Platform"
DEFAULT_PROVIDER  = "groq"  # auto | nvidia | groq | openrouter

# ── Auth: Email Whitelist ──
# Comma-separated list of allowed emails.
# Empty = anyone can register (public demo mode).
# Example: "harsh@example.com,team@example.com"
RAG_ALLOWED_EMAILS = ""

# ── Auth: Admin Emails ──
# Comma-separated. Empty = FIRST registered user becomes admin automatically.
RAG_ADMIN_EMAILS = ""

# ── API Token (for FastAPI shim / load testing / webhooks) ──
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
RAG_API_TOKEN     = "change-this-to-a-random-long-string-of-at-least-32-chars"

# ── Observability: Sentry (optional) ──
# Get DSN: https://sentry.io/
# SENTRY_DSN        = "https://xxxxxxxx@sentry.io/xxxxxxx"
# SENTRY_ENV        = "production"

# ── Rate Limiting: Redis URL (optional) ──
# If not set, falls back to in-memory (per-process) rate limiter.
# For production with multiple workers, USE Redis.
# REDIS_URL         = "redis://localhost:6379/0"

# ── Logging ──
LOG_LEVEL         = "INFO"  # DEBUG | INFO | WARNING | ERROR

# ── Public Demo Mode ──
# true  = anyone can register, strict quotas, demo banner shown
# false = auth required, generous limits, no demo banner
PUBLIC_MODE       = true

# ── Branding Links (optional) ──
GITHUB_URL        = "https://github.com/yourusername/smart-doc-qa"
LINKEDIN_URL      = "https://www.linkedin.com/in/yourprofile"
