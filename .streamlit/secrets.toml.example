# ============================================================
# 🛡️ FIX F-12: Streamlit Secrets Template
# ============================================================
# Copy this file to .streamlit/secrets.toml and fill in your keys.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# ⚠️  NEVER commit secrets.toml to git — it's in .gitignore.
# ============================================================

# ── LLM Provider API Keys (any ONE is enough) ──
# Get free NVIDIA key: https://build.nvidia.com/
NVIDIA_API_KEY    = "nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Get free Groq key: https://console.groq.com/
GROQ_API_KEY      = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Get OpenRouter key: https://openrouter.ai/
OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── App Branding ──
OWNER_NAME        = "Harsh Bokde"
DEFAULT_PROVIDER  = "groq"  # auto | nvidia | groq | openrouter

# ── Auth (F-03): Email whitelist for SSO ──
# Comma-separated. Empty = anyone logged in can access.
RAG_ALLOWED_EMAILS = "harsh@example.com,team@example.com"

# ── API Token (for FastAPI shim / load testing) ──
# Generate a random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
RAG_API_TOKEN     = "change-this-to-a-random-long-string"

# ── Observability (F-16): Sentry DSN (optional) ──
# Get DSN: https://sentry.io/
# SENTRY_DSN        = "https://xxxxxxxx@sentry.io/xxxxxxx"
# SENTRY_ENV        = "production"

# ── Rate Limiting (F-10): Redis URL (optional) ──
# If not set, falls back to in-memory (per-process) rate limiter.
# REDIS_URL         = "redis://localhost:6379/0"

# ── Logging ──
LOG_LEVEL         = "INFO"  # DEBUG | INFO | WARNING | ERROR

# ============================================================
# 🔐 ADMIN PANEL CREDENTIALS
# ============================================================
# Admin panel access karne ke liye:
# 1. In credentials se login karo
# 2. URL me ?admin=true add karo (e.g., https://your-app.streamlit.app/?admin=true)
# 3. User list + activity log dikhega
#
# ⚠️ CHANGE THESE before deploying!
# Generate strong password: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_EMAIL       = "admin@rag.app"
ADMIN_PASSWORD    = "admin123"  # ← CHANGE THIS!
